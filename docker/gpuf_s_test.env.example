# Copy to .env.gpuf-s-test and change every secret before using a shared test host.
# The real .env file is ignored by git.

GPUF_TEST_POSTGRES_USER=postgres
GPUF_TEST_POSTGRES_PASSWORD=change-me-test-postgres-password
GPUF_TEST_POSTGRES_DB=GPUFabric

# Must be exactly 48 characters because tokens.key is char(48).
GPUF_TEST_GATEWAY_TOKEN=0123456789abcdef0123456789abcdef0123456789abcdef

# Must be 16 bytes / 32 hex chars. gpuf-c uses this for --client-id.
GPUF_TEST_CLIENT_ID_HEX=50ef7b5e7b5b4c79991087bb9f62cef1
GPUF_TEST_USER_ID=1

GPUF_TEST_CONTROL_PORT=17100
GPUF_TEST_PROXY_PORT=17101
GPUF_TEST_PUBLIC_PORT=18180
GPUF_TEST_API_PORT=18181
GPUF_TEST_INFERENCE_GATEWAY_PORT=18182
GPUF_TEST_POSTGRES_PORT=15432
GPUF_TEST_REDIS_PORT=16379
GPUF_TEST_ZOOKEEPER_PORT=12181
GPUF_TEST_KAFKA_HOST_PORT=39092

GPUF_TEST_RUST_LOG=gpuf-s=info,api_server=info,heartbeat_consumer=info
